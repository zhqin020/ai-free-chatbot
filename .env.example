# AI-Free-Chatbot Environment Configuration

# Application Settings
APP_NAME=ai-free-chatbot
APP_ENV=production  # dev, production, test
LOG_LEVEL=INFO      # DEBUG, INFO, WARNING, ERROR

# Database Configuration
# Default uses local SQLite in the data/ directory
DB_URL=sqlite:///data/app.db

# API Security
# Token used to authorize requests to the API
API_TOKEN=your-very-secret-token

# Client/Example Settings
# Base URL for the client to connect to the API
API_BASE_URL=http://localhost:8000
